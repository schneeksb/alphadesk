# Copy to .env for local dev (never commit the real file — it's gitignored).
# In production, set these in the Render dashboard instead.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Frontend auth (Supabase + Google) — these are VITE_ vars and go in app/.env.local,
# NOT here. See SUPABASE_SETUP.md.
#   VITE_SUPABASE_URL=https://<project>.supabase.co
#   VITE_SUPABASE_ANON_KEY=eyJ...

# Optional (scanner.py notifications):
# SLACK_WEBHOOK_URL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_TO_NUMBER=
